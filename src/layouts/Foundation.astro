---
import '../assets/styles/tailwind.css';

interface Props {
  lang?: 'en' | 'he';
  dir?: 'ltr' | 'rtl';
  title?: string;
}

const { lang = 'en', dir = 'ltr', title = 'Lior Tabansky' } = Astro.props;
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-black">
    <main class="mx-auto min-h-screen max-w-7xl px-6 py-12">
      <slot />
    </main>
  </body>
</html>
