---
const { lang = 'en' } = Astro.props;
const en = lang === 'en';
---
<footer class="footer">
  <div class="site-container footer__grid">
    <div>
      <p class="footer__name">Dr. Lior Tabansky</p>
      <p class="footer__positioning">{en ? 'First-principles strategy for defense innovation, AI, and digital trust.' : 'אסטרטגיה מעקרונות יסוד — לחדשנות ביטחונית, לבינה מלאכותית ולאמון דיגיטלי.'}</p>
    </div>
    <div class="footer__contact">
      <p>{en ? 'For advisory, investment, or media inquiries' : 'לפניות בענייני ייעוץ, השקעות או תקשורת'}</p>
      <a href="https://www.linkedin.com/in/ltaba/" rel="me">LinkedIn <span class="directional-arrow" aria-hidden="true">→</span></a>
    </div>
    <p class="footer__legal">© 2026 Dr. Lior Tabansky</p>
  </div>
</footer>
