---
const { lang = 'en' } = Astro.props;
const en = lang === 'en';
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const base = `${root}${en ? 'en' : 'he'}`;
const t = en ? { home:'Home', media:'Media', about:'About', writing:'Writing' } : { home:'בית', media:'תקשורת', about:'אודות', writing:'כתיבה' };
const navLabel = en ? 'Primary navigation' : 'ניווט ראשי';
const languageLabel = en ? 'Choose language' : 'בחירת שפה';
const localPath = Astro.url.pathname.startsWith(root) ? Astro.url.pathname.slice(root.length) : Astro.url.pathname.replace(/^\/+/, '');
const route = localPath.replace(/^(en|he)(\/|$)/, '').replace(/^\/+|\/+$/g, '');
const routeSuffix = route ? `${route}/` : '';
const currentRoute = route || 'home';
const items = [
  { key: 'home', label: t.home, href: `${base}/` },
  { key: 'media', label: t.media, href: `${base}/media/` },
  { key: 'about', label: t.about, href: `${base}/about/` },
  { key: 'writing', label: t.writing, href: `${base}/writing/` },
];
---
<header class="nav">
  <div class="site-container nav__inner">
    <a class="brand" href={`${base}/`}>Dr. Lior Tabansky</a>
    <nav class="primary-nav" aria-label={navLabel}>
      <ul class="primary-nav__list">
        {items.map((item) => (
          <li><a href={item.href} aria-current={currentRoute === item.key ? 'page' : undefined}>{item.label}</a></li>
        ))}
      </ul>
      <div class="language-switch" aria-label={languageLabel}>
        <a href={`${root}en/${routeSuffix}`} lang="en" aria-current={en ? 'true' : undefined}>EN</a>
        <span aria-hidden="true">/</span>
        <a href={`${root}he/${routeSuffix}`} lang="he" dir="rtl" aria-current={!en ? 'true' : undefined}>עב</a>
      </div>
    </nav>
  </div>
</header>
