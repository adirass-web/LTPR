---
import SiteShell from '~/components/SiteShell.astro';
import { siteContent, type Locale, type PageKey } from '~/content/site';

interface Props {
  locale: Locale;
  page: PageKey;
}

const { locale, page } = Astro.props;
const content = siteContent[locale].pages[page];
---

<SiteShell locale={locale} page={page}>
  <section class="page-intro">
    <p class="eyebrow">{content.nav}</p>
    <h1>{content.title}</h1>
  </section>
</SiteShell>
