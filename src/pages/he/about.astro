---
import Base from '../../layouts/Base.astro';
import Portrait from '../../components/Portrait.astro';
---
<Base title="אודות — ד״ר ליאור טבנסקי" description="עמוד אודות בעברית נמצא בהכנה ובבדיקת ניסוח." lang="he" dir="rtl">
  <div class="page page--about">
    <header class="page-section page-header">
      <div class="site-container page-header__layout"><div><p class="eyebrow">אודות</p><h1>אסטרטגיה שעומדת במבחן המציאות.</h1></div><div class="page-header__aside"><Portrait variant="square" alt="ד״ר ליאור טבנסקי" /><p class="subhead">הגרסה העברית המלאה נמצאת בהכנה ובבדיקת ניסוח.</p></div></div>
    </header>
    <section class="page-section status-section" aria-labelledby="about-status-title">
      <div class="site-container section-grid"><header class="section-heading"><p class="eyebrow">סטטוס</p><h2 id="about-status-title">הפריסה הושלמה. התרגום בבדיקה.</h2></header><p class="feature-copy">עמוד זה משתמש באותה ארכיטקטורת תוכן ובאותה מערכת עיצוב של הגרסה האנגלית, עם כיוון קריאה מלא מימין לשמאל. הנוסח המלא יפורסם לאחר סקירה עברית.</p></div>
    </section>
    <section class="page-section inquiry-section" aria-labelledby="about-inquiry-title"><div class="site-container inquiry-layout"><h2 id="about-inquiry-title">לפניות בענייני ייעוץ, השקעות או תקשורת.</h2><a class="text-link" href="https://www.linkedin.com/in/ltaba/">פניות פרטיות <span class="directional-arrow" aria-hidden="true">→</span></a></div></section>
  </div>
</Base>
