import Base from '../../layouts/Base.astro';
---
<Base title="Writing — Dr. Lior Tabansky" description="A few arguments on AI, cyber-power, and cybersecurity capacity building — the thinking behind the work." lang="en" dir="ltr">
  <div class="page page--writing">
    <header class="page-section page-header">
      <div class="site-container page-header__layout">
        <div><p class="eyebrow">Writing</p><h1>Writing.</h1></div>
        <p class="subhead">A few arguments, not a feed. The thinking behind the work.</p>
      </div>
    </header>

    <section class="page-section essays-section" aria-labelledby="essays-title">
      <div class="site-container section-grid">
        <header class="section-heading"><p class="eyebrow">Essays</p><h2 id="essays-title">Arguments in development.</h2></header>
        <ol class="editorial-list">
          <li><article class="editorial-item"><div class="editorial-item__meta"><span>01</span><span>Cornerstone essay</span><span>In development</span></div><div><h3>AI is an organizational problem, not a model problem.</h3><p>AI already delivers insight, decision support, and autonomy. The challenge is no longer whether the capability exists, but whether organizations can use it: successful adoption is an organizational problem, not a model problem.</p></div></article></li>
          <li><article class="editorial-item"><div class="editorial-item__meta"><span>02</span><span>Cyber-power</span><span>In development</span></div><div><h3>From cybersecurity to cyber-power.</h3><p>National advantage doesn't come from defense alone; it comes from how a country turns innovation and organization into strategic capability. The argument behind the book and the NATO work.</p></div></article></li>
          <li><article class="editorial-item"><div class="editorial-item__meta"><span>03</span><span>Capacity building</span><span>In development</span></div><div><h3>Capacity that outlasts the report.</h3><p>Why durable national cyber capability has to be built as a complex socio-technical-economic system — the method behind the World Bank roadmaps.</p></div></article></li>
        </ol>
      </div>
    </section>

    <section class="page-section book-section" aria-labelledby="book-title">
      <div class="site-container book-layout">
        <div class="book-placeholder" aria-hidden="true"><span>Book cover</span></div>
        <article>
          <p class="eyebrow">The book</p>
          <h2 id="book-title"><cite>Cybersecurity in Israel</cite></h2>
          <p class="subhead">Springer, with Maj. Gen. Isaac Ben-Israel.</p>
          <p>A comprehensive analysis of how Israel became a cyber power — strategy, institutions, and the innovation ecosystem behind it.</p>
          <a class="text-link" href="https://link.springer.com/book/10.1007/978-3-319-18986-4">SpringerLink <span class="directional-arrow" aria-hidden="true">→</span></a>
        </article>
      </div>
    </section>

    <section class="page-section publications-section" aria-labelledby="publications-title">
      <div class="site-container section-grid">
        <header class="section-heading"><p class="eyebrow">Selected publications</p><h2 id="publications-title">Research and commentary.</h2></header>
        <ul class="record-list publication-list">
          <li><cite>“Towards a Theory of Cyber Power”</cite><span>NATO CCDCOE, Conference on Cyber Conflict (CyCon)</span></li>
          <li><cite>“Incorporating Systems Thinking into a Cyber Resilience Maturity Model”</cite><span>IEEE Engineering Management Review</span></li>
          <li><cite>“Can Cyber Intelligence Collection Support Human Rights?”</cite><span>The National Interest</span></li>
        </ul>
      </div>
    </section>

    <section class="page-section inquiry-section" aria-labelledby="writing-inquiry-title">
      <div class="site-container inquiry-layout">
        <h2 id="writing-inquiry-title">For advisory, investment, or media inquiries.</h2>
        <a class="text-link" href="https://www.linkedin.com/in/ltaba/">Private inquiries <span class="directional-arrow" aria-hidden="true">→</span></a>
      </div>
    </section>
  </div>
</Base>
