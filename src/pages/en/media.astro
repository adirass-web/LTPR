---
import Base from '../../layouts/Base.astro';
const root = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---
<Base title="Media — Dr. Lior Tabansky" description="Selected television, press, and speaking — Dr. Lior Tabansky on RAI, in the Financial Times, Le Figaro, The Washington Post, and at NATO and national parliaments." lang="en" dir="ltr">
  <div class="page page--media">
    <header class="page-section page-header">
      <div class="site-container page-header__layout">
        <div><p class="eyebrow">Media</p><h1>Media.</h1></div>
        <p class="subhead">Selected appearances and coverage. The outlets speak for themselves.</p>
      </div>
    </header>

    <section class="page-section video-section" aria-labelledby="video-title">
      <div class="site-container">
        <header class="section-heading section-heading--wide"><p class="eyebrow">TV & Video</p><h2 id="video-title">On screen.</h2></header>
        <figure class="featured-media featured-media--lead">
          <div class="media-placeholder" aria-hidden="true"><span>RAI</span><small>60–90s subtitled edit in preparation</small></div>
          <figcaption>On <strong>RAI</strong>, Italy's public broadcaster — <cite>Codice: La vita è digitale</cite>.</figcaption>
        </figure>
        <div class="media-index" aria-label="Additional television appearances">
          <article class="media-index__item"><p class="item-label">English broadcast</p><h3>i24</h3><p>International television appearance. Final clip and topic caption are being selected.</p></article>
          <article class="media-index__item"><p class="item-label">International broadcasts</p><h3>Selected appearances</h3><p>A curated set of five to eight appearances will be embedded after the final editorial and rights review.</p></article>
          <article class="media-index__item media-index__item--link"><p class="item-label">Video archive</p><h3>YouTube</h3><a class="text-link" href="https://www.youtube.com/@ltabansky6248/videos">View the channel <span class="directional-arrow" aria-hidden="true">→</span></a></article>
        </div>
      </div>
    </section>

    <section class="page-section press-section" aria-labelledby="press-title">
      <div class="site-container">
        <header class="section-heading section-heading--wide"><p class="eyebrow">Press & Features</p><h2 id="press-title">International and regional coverage.</h2><p class="section-caption">Verified article links and normalized monochrome marks will replace these text references.</p></header>
        <div class="press-groups">
          <section class="press-group" aria-labelledby="international-press-title">
            <h3 id="international-press-title">International</h3>
            <ul class="brand-grid"><li>Financial Times</li><li>The Washington Post / AP</li><li>Le Figaro</li><li>La Repubblica</li><li>Il Sole 24 Ore</li><li>NRC Handelsblad</li><li>Newsweek</li></ul>
          </section>
          <section class="press-group" aria-labelledby="regional-press-title">
            <h3 id="regional-press-title">Regional</h3>
            <ul class="brand-grid"><li>The Jerusalem Post</li><li>The Times of Israel</li><li>Haaretz</li><li>Il Giornale</li><li>Gazeta Wyborcza</li><li>CyberDefence24</li></ul>
          </section>
        </div>
        <aside class="editorial-note">Bylined commentary in <cite>The National Interest</cite> is Dr. Tabansky's own writing, not coverage. <a class="text-link" href={`${root}en/writing/`}>See Writing <span class="directional-arrow" aria-hidden="true">→</span></a></aside>
      </div>
    </section>

    <section class="page-section speaking-section" aria-labelledby="speaking-title">
      <div class="site-container section-grid">
        <header class="section-heading"><p class="eyebrow">Speaking</p><h2 id="speaking-title">Selected institutions and forums.</h2></header>
        <ul class="record-list record-list--split">
          <li>NATO CCDCOE, Conference on Cyber Conflict (CyCon) — Tallinn, Estonia</li>
          <li>Public hearing, Folketinget (Danish Parliament) — Copenhagen</li>
          <li>Camera dei Deputati (Italian Chamber of Deputies) — Rome</li>
          <li>Future of War — Amsterdam</li>
          <li>Total Defense Conference — Lillehammer, Norway</li>
          <li>Cyber Storm, UNSW — Canberra, Australia</li>
          <li>People's Security Academy — Hanoi, Vietnam</li>
          <li>APPSNO — Singapore</li>
          <li>NY State Cyber Security Conference — Albany, USA</li>
          <li>Cyber Week — Tel Aviv</li>
        </ul>
      </div>
    </section>

    <section class="page-section press-kit-section" aria-labelledby="press-kit-title">
      <div class="site-container section-grid">
        <header class="section-heading"><p class="eyebrow">Press kit</p><h2 id="press-kit-title">For editors and producers.</h2></header>
        <div class="feature-copy"><p>Short and long biographies in English and Hebrew, approved high-resolution headshots, and a media contact will be connected after final asset approval.</p><a class="text-link" href="https://www.linkedin.com/in/ltaba/">Media inquiries <span class="directional-arrow" aria-hidden="true">→</span></a></div>
      </div>
    </section>
  </div>
</Base>
